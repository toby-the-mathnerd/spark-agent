# skill: spark-update-task
# purpose: Update task file in spark-tasks after each meaningful step
# triggers: After completing any workflow phase

## Invocation
```
spark-update-task <task-id> --status <active|blocked|done> [--message <update-message>]
```

## Implementation Flow

### 1. Load Task Context
```bash
#!/bin/bash
# spark-update-task.skill implementation

TASK_ID="$1"
STATUS="$2"
MESSAGE="${3:-Work in progress}"
SPARK_TASKS_DIR="$HOME/spark-tasks"
WORKSPACE="$HOME/claude-workspace/agentic-workflows"

# Find task file
if [ "$STATUS" = "blocked" ]; then
    TASK_FILE=$(find "$SPARK_TASKS_DIR/tasks/blocked" -name "*task-$TASK_ID*.md" 2>/dev/null | head -1)
else
    TASK_FILE=$(find "$SPARK_TASKS_DIR/tasks/active" -name "*task-$TASK_ID*.md" 2>/dev/null | head -1)
fi

if [ ! -f "$TASK_FILE" ]; then
    echo "Error: Task file not found"
    exit 1
fi
```

### 2. Update Task File
```bash
update_task_file() {
    local task_file="$TASK_FILE"
    local status="$STATUS"
    local message="$MESSAGE"
    local timestamp=$(date +%Y-%m-%d\ %H:%M)

    # Update status line
    sed -i "s/\*\*Status\*\*: .*/\*\*Status\*\*: $status/" "$task_file"

    # Add update entry
    # Find the Updates section and add after it
    awk -v ts="$timestamp" -v msg="$message" '
        /^## Updates/ { print; print "- " ts ": " msg; next }
        { print }
    ' "$task_file" > "${task_file}.tmp"

    mv "${task_file}.tmp" "$task_file"
}
```

### 3. Log Tool Call
```bash
log_tool_call() {
    local task_id="$TASK_ID"
    local session_id=$(cat "$WORKSPACE/tasks/$task_id/.session_id" 2>/dev/null || date +%Y%m%d-%H%M%S)
    local tool="$1"
    local tokens_in="${2:-0}"
    local tokens_out="${3:-0}"
    local duration_ms="${4:-0}"
    local success="${5:-true}"
    local error="${6:-null}"

    RUNS_DIR="$SPARK_TASKS_DIR/agents/runs"
    mkdir -p "$RUNS_DIR"

    cat >> "$RUNS_DIR/$session_id.jsonl" << EOF
{"task_id": "task-$task_id", "session_id": "$session_id", "timestamp": "$(date -Iseconds)", "model": "qwen3.5:122b-a10b", "tool": "$tool", "tokens_in": $tokens_in, "tokens_out": $tokens_out, "duration_ms": $duration_ms, "success": $success, "error": $error}
EOF
}
```

### 4. Commit and Push
```bash
commit_and_push() {
    local task_file="$TASK_FILE"
    local task_id="$TASK_ID"

    # Commit task file update
    git -C "$SPARK_TASKS_DIR" add "$task_file"
    git -C "$SPARK_TASKS_DIR" commit -m "[Spark 2] Task $task_id: $MESSAGE"
    git -C "$SPARK_TASKS_DIR" push

    echo "Updated and pushed: $(basename $task_file)"
}
```

### 5. Full Update Flow
```bash
# Example usage from RPOLES workflow:

# After dev-review completes:
spark-update-task "$TASK_ID" --status active --message "Review complete, proceeding to planning"

# After each implementation step:
spark-update-task "$TASK_ID" --status active --message "Created $filename with tests"

# When blocked:
spark-update-task "$TASK_ID" --status blocked --message "Need clarification on acceptance criteria"

# When done:
spark-update-task "$TASK_ID" --status done --message "Task completed, see Result section"
```
