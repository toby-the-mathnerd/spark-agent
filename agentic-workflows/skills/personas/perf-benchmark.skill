# skill: perf-benchmark
# purpose: Create and run performance benchmarks (Performance Persona - Phase 2)
# triggers: Analysis complete, code ready for benchmarking

## Invocation
```
perf-benchmark <task-id> [--analysis <analysis-file>] [--iterations <count>]
```

## Output
Creates: Benchmark scripts + `memory/tasks/<task-id>/benchmark-results.md`

## Implementation Flow

### 1. Create Benchmarks
```bash
#!/bin/bash
# perf-benchmark.skill implementation

TASK_ID="$1"
ANALYSIS_FILE="${2:-memory/tasks/$TASK_ID/perf-analysis.md}"
ITERATIONS="${3:-100}"

mkdir -p "benchmarks/perf_$TASK_ID"
```

### 2. Generate Benchmark Suite
```python
# benchmarks/perf_<task_id>/test_performance.py

"""
Performance Benchmarks for Task $TASK_ID
Generated by: perf-benchmark
"""

import pytest
import time
import memory_profiler
from <module> import <component>


class TestPerformance:
    """Performance benchmark suite"""

    @pytest.fixture
    def setup_benchmark(self):
        """Set up benchmark environment"""
        # Prepare test data
        self.test_data = generate_test_data()
        self.component = <component>()
        yield
        # Cleanup
        del self.component

    def benchmark_response_time(self, setup_benchmark, iterations=$ITERATIONS):
        """
        Benchmark: Response Time
        Target: <ms>ms
        """
        times = []

        for _ in range(iterations):
            start = time.perf_counter()
            result = self.component.process(self.test_data)
            end = time.perf_counter()
            times.append((end - start) * 1000)  # Convert to ms

        avg_time = sum(times) / len(times)
        p95_time = sorted(times)[int(len(times) * 0.95)]
        p99_time = sorted(times)[int(len(times) * 0.99)]

        print(f"\nResponse Time Results:")
        print(f"  Average: {avg_time:.2f}ms")
        print(f"  P95: {p95_time:.2f}ms")
        print(f"  P99: {p99_time:.2f}ms")

        assert avg_time < TARGET_AVG_MS, f"Avg {avg_time:.2f}ms exceeds target {TARGET_AVG_MS}ms"

    def benchmark_throughput(self, setup_benchmark, iterations=$ITERATIONS):
        """
        Benchmark: Throughput (requests/second)
        Target: <req/s>
        """
        start = time.perf_counter()

        for _ in range(iterations):
            result = self.component.process(self.test_data)

        end = time.perf_counter()
        throughput = iterations / (end - start)

        print(f"\nThroughput Results:")
        print(f"  {throughput:.2f} req/s")

        assert throughput >= TARGET_THROUGHPUT, f"{throughput:.2f} req/s below target {TARGET_THROUGHPUT}"

    def benchmark_memory_usage(self, setup_benchmark):
        """
        Benchmark: Memory Usage
        Target: <MB>
        """
        @memory_profiler.profile
        def process_data():
            return self.component.process(self.test_data)

        result = process_data()

        print(f"\nMemory Usage Results:")
        # Memory profiler outputs to console

    def benchmark_concurrent(self, setup_benchmark, workers=10):
        """
        Benchmark: Concurrent Load
        Target: <workers> concurrent requests
        """
        from concurrent.futures import ThreadPoolExecutor

        def worker(i):
            start = time.perf_counter()
            result = self.component.process(self.test_data)
            end = time.perf_counter()
            return end - start

        with ThreadPoolExecutor(max_workers=workers) as executor:
            futures = [executor.submit(worker, i) for i in range(workers)]
            results = [f.result() for f in futures]

        avg_time = sum(results) / len(results)
        print(f"\nConcurrent Load Results ({workers} workers):")
        print(f"  Average time: {avg_time * 1000:.2f}ms")

        assert avg_time < CONCURRENT_TARGET_MS
```

### 3. Run Benchmarks
```bash
run_benchmarks() {
    local task_id="$1"
    local benchmark_dir="benchmarks/perf_$task_id"

    echo "Running performance benchmarks..."

    # Run Python benchmarks
    if command -v pytest &> /dev/null; then
        pytest "$benchmark_dir" -v --tb=short \
            --benchmark-json="memory/tasks/$task_id/benchmark-data.json" \
            2>&1 | tee "memory/tasks/$task_id/benchmark-output.log"
    fi
}
```

### 4. Generate Results Report
```bash
cat > "memory/tasks/$TASK_ID/benchmark-results.md" << EOF
# Benchmark Results: $TASK_ID

## Test Configuration
**Iterations:** $ITERATIONS
**Date:** $(date +%Y-%m-%d)
**Environment:** <test environment>

## Results Summary

### Response Time
| Metric | Target | Actual | Status |
|--------|--------|--------|--------|
| Average | <target>ms | <actual>ms | ✓/✗ |
| P95 | <target>ms | <actual>ms | ✓/✗ |
| P99 | <target>ms | <actual>ms | ✓/✗ |

### Throughput
| Metric | Target | Actual | Status |
|--------|--------|--------|--------|
| Requests/sec | <target> | <actual> | ✓/✗ |

### Memory Usage
| Metric | Target | Actual | Status |
|--------|--------|--------|--------|
| Peak | <target>MB | <actual>MB | ✓/✗ |

### Concurrent Load
| Workers | Target Latency | Actual Latency | Status |
|---|---|---|---|
| <n> | <target>ms | <actual>ms | ✓/✗ |

## Detailed Results
\`\`\`
$(cat "memory/tasks/$task_id/benchmark-output.log" 2>/dev/null || "No output")
\`\`\`

## Bottlenecks Identified
1. <bottleneck 1>
2. <bottleneck 2>

## Recommendations
### Immediate Actions
- <action 1>
- <action 2>

### Optimization Opportunities
- <opportunity 1>

## Sign-off
**Performance Status:** ✓ MEETS REQUIREMENTS | ⚠ ACCEPTABLE | ✗ NEEDS OPTIMIZATION

**Next:** perf-optimize (if needed)
EOF
```

### 5. Checkpoint
```bash
checkpoint --phase custom --description "Benchmarks complete for $TASK_ID" \
    --next "Review results and optimize if needed"
```
