# skill: qa-generate-tests
# purpose: Create test cases based on QA plan (QA Persona - Phase 2)
# triggers: QA plan approved

## Invocation
```
qa-generate-tests <task-id> [--qa-plan <qa-plan-file>] [--output-dir <tests-dir>]
```

## Output
Creates: Test files in specified output directory

## Implementation Flow

### 1. Load Context
```bash
#!/bin/bash
# qa-generate-tests.skill implementation

TASK_ID="$1"
QA_PLAN="${2:-memory/tasks/$TASK_ID/qa-plan.md}"

if [ ! -f "$QA_PLAN" ]; then
    echo "Error: QA plan not found. Run qa-analyze first."
    exit 1
fi

QA_PLAN_CONTENT=$(cat "$QA_PLAN")
```

### 2. Generate Unit Tests
```bash
generate_unit_tests() {
    local task_id="$1"
    local output_dir="${2:-tests}"

    mkdir -p "$output_dir/unit"

    # Parse test cases from QA plan
    local test_cases=$(grep -E "^\| AC[0-9]+" "$QA_PLAN" | cut -d'|' -f3)

    for test_case in $test_cases; do
        cat > "$output_dir/unit/test_${task_id}_${test_case}.py" << EOF
"""
Unit tests for Task $task_id
Generated by: qa-generate-tests
"""

import pytest
from unittest.mock import Mock, patch
from <module> import <component>


class Test${test_case^^}:
    """Test case: $test_case"""

    def setup_method(self):
        """Set up test fixtures"""
        self.<fixture> = <setup>

    def test_${test_case}_success(self):
        """Test successful execution"""
        # Arrange
        <inputs>

        # Act
        result = <operation>

        # Assert
        assert result == <expected>
        assert <condition>

    def test_${test_case}_validation(self):
        """Test input validation"""
        # Arrange
        invalid_input = <invalid_data>

        # Act & Assert
        with pytest.raises(ValidationError):
            <operation>(invalid_input)

    def test_${test_case}_error_handling(self):
        """Test error handling"""
        # Arrange
        self.mock_dependency.side_effect = <exception>

        # Act & Assert
        with pytest.raises(<ExceptionType>):
            <operation>()

    def test_${test_case}_edge_cases(self):
        """Test edge cases"""
        # Test boundary values
        edge_cases = [
            (<boundary1>, <expected1>),
            (<boundary2>, <expected2>),
        ]

        for input_val, expected in edge_cases:
            result = <operation>(input_val)
            assert result == expected
EOF
    done
}
```

### 3. Generate Integration Tests
```bash
generate_integration_tests() {
    local task_id="$1"
    local output_dir="${2:-tests}"

    mkdir -p "$output_dir/integration"

    cat > "$output_dir/integration/test_${task_id}_integration.py" << EOF
"""
Integration tests for Task $task_id
Generated by: qa-generate-tests
"""

import pytest
from <module> import <component>


@pytest.fixture
def integration_setup():
    """Set up integration test environment"""
    # Setup database, services, etc.
    setup = <setup>
    yield setup
    # Cleanup
    teardown(setup)


@pytest.mark.integration
class Test${task_id}Integration:
    """Integration tests for $task_id"""

    def test_full_workflow(self, integration_setup):
        """Test complete workflow"""
        # Arrange
        workflow_data = <data>

        # Act
        result = run_workflow(workflow_data)

        # Assert
        assert result.status == "completed"
        assert result.output == <expected>

    def test_data_persistence(self, integration_setup):
        """Test data is persisted correctly"""
        # Arrange
        data = <data>

        # Act
        save_data(data)

        # Assert
        persisted = load_data(data.id)
        assert persisted == data

    def test_api_endpoints(self, integration_setup):
        """Test all API endpoints"""
        client = integration_setup.test_client

        # Test each endpoint
        endpoints = [
            ("GET", "/api/resource"),
            ("POST", "/api/resource"),
            ("PUT", "/api/resource/{id}"),
            ("DELETE", "/api/resource/{id}"),
        ]

        for method, path in endpoints:
            response = client.request(method, path)
            assert response.status_code in [200, 201, 204]
EOF
}
```

### 4. Generate Test Report
```bash
create_test_manifest() {
    local task_id="$1"
    local output_dir="${2:-tests}"

    cat > "memory/tasks/$task_id/test-manifest.md" << EOF
# Test Manifest: $task_id

## Generated Tests

### Unit Tests
$(find "$output_dir/unit" -name "*.py" -exec echo "- {}" \; 2>/dev/null || echo "No unit tests generated")

### Integration Tests
$(find "$output_dir/integration" -name "*.py" -exec echo "- {}" \; 2>/dev/null || echo "No integration tests generated")

## Coverage Requirements
- Unit test coverage: >80%
- Integration test coverage: critical paths only

## Execution
\`\`\`bash
# Run unit tests
pytest $output_dir/unit -v

# Run integration tests
pytest $output_dir/integration -v -m integration

# Run all tests with coverage
pytest $output_dir -v --cov=<module> --cov-report=html
\`\`\`
EOF
}
```

### 5. Checkpoint
```bash
checkpoint --phase custom --description "Test suite generated for $TASK_ID" \
    --next "Run tests with qa-validate"
```
