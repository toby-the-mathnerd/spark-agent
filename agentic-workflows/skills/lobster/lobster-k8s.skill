# skill: lobster-k8s
# purpose: Generate repeatable Kubernetes manifests
# triggers: K8s deployment task received

## Invocation
```
lobster-k8s <task-id> --service-type <type> --replicas <count> \
    --resources <limits> [--ingress]
```

## Output
Creates: `lobster/k8s/{{task_id}}/` with all K8s manifests

## Implementation Flow

### 1. Load Context
```bash
#!/bin/bash
# lobster-k8s.skill implementation

TASK_ID="$1"
SERVICE_TYPE="${2:-ClusterIP}"
REPLICAS="${3:-3}"
RESOURCES="${4:-medium}"

mkdir -p "lobster/k8s/$TASK_ID"
mkdir -p "lobster/k8s/$TASK_ID/base"
mkdir -p "lobster/k8s/$TASK_ID/overlays/{dev,staging,prod}"
```

### 2. Generate Namespace
```yaml
# lobster/k8s/{{task_id}}/base/namespace.yml
apiVersion: v1
kind: Namespace
metadata:
  name: {{task_id}}
  labels:
    app: {{task_id}}
    managed-by: lobster-workflow
```

### 3. Generate Deployment
```yaml
# lobster/k8s/{{task_id}}/base/deployment.yml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{task_id}}
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
spec:
  replicas: {{replicas}}
  selector:
    matchLabels:
      app: {{task_id}}
  template:
    metadata:
      labels:
        app: {{task_id}}
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{port}}"
    spec:
      serviceAccountName: {{task_id}}-sa
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        fsGroup: 1000
      containers:
        - name: {{task_id}}
          image: ghcr.io/{{repo}}/{{task_id}}:latest
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{port}}
              protocol: TCP
          env:
            - name: APP_ENV
              valueFrom:
                configMapKeyRef:
                  name: {{task_id}}-config
                  key: APP_ENV
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: {{task_id}}-secrets
                  key: DATABASE_URL
            - name: SECRET_KEY
              valueFrom:
                secretKeyRef:
                  name: {{task_id}}-secrets
                  key: SECRET_KEY
          resources:
            {% if resources == 'small' %}
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "256Mi"
              cpu: "200m"
            {% elif resources == 'medium' %}
            requests:
              memory: "256Mi"
              cpu: "200m"
            limits:
              memory: "512Mi"
              cpu: "500m"
            {% elif resources == 'large' %}
            requests:
              memory: "512Mi"
              cpu: "500m"
            limits:
              memory: "1Gi"
              cpu: "1000m"
            {% endif %}
          livenessProbe:
            httpGet:
              path: /health
              port: http
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /ready
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
            timeoutSeconds: 3
            failureThreshold: 3
          securityContext:
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: true
            capabilities:
              drop:
                - ALL
      terminationGracePeriodSeconds: 30
```

### 4. Generate Service
```yaml
# lobster/k8s/{{task_id}}/base/service.yml
apiVersion: v1
kind: Service
metadata:
  name: {{task_id}}
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
spec:
  type: {{service_type}}
  ports:
    - port: 80
      targetPort: http
      protocol: TCP
      name: http
  selector:
    app: {{task_id}}
```

### 5. Generate ConfigMap & Secrets
```yaml
# lobster/k8s/{{task_id}}/base/configmap.yml
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{task_id}}-config
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
data:
  APP_ENV: "production"
  APP_LOG_LEVEL: "info"
  # Add additional config keys here

---
# lobster/k8s/{{task_id}}/base/secrets.yml
# NOTE: Use sealed-secrets or external-secrets for production
apiVersion: v1
kind: Secret
metadata:
  name: {{task_id}}-secrets
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
type: Opaque
stringData:
  DATABASE_URL: "postgresql://user:password@host:5432/dbname"
  SECRET_KEY: "change-me-in-production"
  API_KEY: "change-me-in-production"
```

### 6. Generate ServiceAccount & RBAC
```yaml
# lobster/k8s/{{task_id}}/base/rbac.yml
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{task_id}}-sa
  namespace: {{task_id}}
  labels:
    app: {{task_id}}

---
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{task_id}}-role
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
rules:
  - apiGroups: [""]
    resources: ["configmaps", "secrets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: [""]
    resources: ["events"]
    verbs: ["create", "patch"]

---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{task_id}}-rolebinding
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
subjects:
  - kind: ServiceAccount
    name: {{task_id}}-sa
    namespace: {{task_id}}
roleRef:
  kind: Role
  name: {{task_id}}-role
  apiGroup: rbac.authorization.k8s.io
```

### 7. Generate Ingress (optional)
```yaml
# lobster/k8s/{{task_id}}/base/ingress.yml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{task_id}}-ingress
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
  annotations:
    kubernetes.io/ingress.class: nginx
    cert-manager.io/cluster-issuer: letsencrypt-prod
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/proxy-body-size: "50m"
spec:
  tls:
    - hosts:
        - {{hostname}}
      secretName: {{task_id}}-tls
  rules:
    - host: {{hostname}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{task_id}}
                port:
                  number: 80
```

### 8. Generate HPA
```yaml
# lobster/k8s/{{task_id}}/base/hpa.yml
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{task_id}}-hpa
  namespace: {{task_id}}
  labels:
    app: {{task_id}}
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{task_id}}
  minReplicas: {{replicas}}
  maxReplicas: 10
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 70
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 80
  behavior:
    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
        - type: Percent
          value: 50
          periodSeconds: 60
    scaleUp:
      stabilizationWindowSeconds: 0
      policies:
        - type: Percent
          value: 100
          periodSeconds: 15
        - type: Pods
          value: 4
          periodSeconds: 15
      selectPolicy: Max
```

### 9. Generate Kustomize Base
```yaml
# lobster/k8s/{{task_id}}/base/kustomization.yml
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - namespace.yml
  - deployment.yml
  - service.yml
  - configmap.yml
  - secrets.yml
  - rbac.yml
  - hpa.yml
  # - ingress.yml  # Uncomment if needed

commonLabels:
  app: {{task_id}}
  managed-by: lobster-workflow

namespace: {{task_id}}
```

### 10. Generate Environment Overlays
```yaml
# lobster/k8s/{{task_id}}/overlays/dev/kustomization.yml
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization
resources:
  - ../../base

namePrefix: dev-

patches:
  - patch: |-
      - op: replace
        path: /spec/replicas
        value: 1
    target:
      kind: Deployment
      name: {{task_id}}

  - patch: |-
      - op: replace
        path: /spec/minReplicas
        value: 1
    target:
      kind: HorizontalPodAutoscaler

configMapGenerator:
  - name: {{task_id}}-config
    behavior: merge
    literals:
      - APP_ENV=development
      - APP_LOG_LEVEL=debug
```

### 11. Checkpoint
```bash
checkpoint --phase custom --description "Kubernetes manifests generated for $TASK_ID" \
    --next "Review and apply manifests to cluster"
```
